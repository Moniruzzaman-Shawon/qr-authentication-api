# ---------------------------------------------------------------------------
# Core
# ---------------------------------------------------------------------------
# Set DEBUG=False in production.
DEBUG=True
# REQUIRED when DEBUG=False. Generate with:
#   python -c "from django.core.management.utils import get_random_secret_key as k; print(k())"
SECRET_KEY=
# Optional separate key for signing QR payloads (defaults to SECRET_KEY).
QR_SIGNING_KEY=
# Comma-separated. Required when DEBUG=False.
ALLOWED_HOSTS=localhost,127.0.0.1
# Public URL of the customer-facing frontend. Embedded into every QR code.
FRONTEND_URL=http://localhost:5173

# ---------------------------------------------------------------------------
# CORS / CSRF
# ---------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=

# ---------------------------------------------------------------------------
# Database (leave DB_NAME/DATABASE_URL blank to use SQLite)
# ---------------------------------------------------------------------------
DB_NAME=
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# ---------------------------------------------------------------------------
# JWT
# ---------------------------------------------------------------------------
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=7

# ---------------------------------------------------------------------------
# Throttling
# ---------------------------------------------------------------------------
THROTTLE_VERIFY=20/min
THROTTLE_CHECK=60/min
THROTTLE_LOGIN=10/min

# ---------------------------------------------------------------------------
# Login security (brute-force lockout)
# ---------------------------------------------------------------------------
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# ---------------------------------------------------------------------------
# White-label branding (seeds the editable Settings page on first run;
# afterwards edit it in the admin under Settings)
# ---------------------------------------------------------------------------
BRAND_APP_NAME=QRShield
BRAND_TAGLINE=QR Authentication & Anti-Counterfeit
BRAND_COMPANY=QRShield
BRAND_SUPPORT_EMAIL=support@qrshield.com
BRAND_ACCENT=#ef4444

# ---------------------------------------------------------------------------
# Initial admin (created by: python manage.py seed_admin)
# ---------------------------------------------------------------------------
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_EMAIL=admin@qrshield.com
INITIAL_ADMIN_PASSWORD=

# ---------------------------------------------------------------------------
# Email (SMTP). In DEBUG, emails print to the console by default.
# ---------------------------------------------------------------------------
EMAIL_BACKEND=
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=alerts@qrshield.com

# ---------------------------------------------------------------------------
# Alerts
# ---------------------------------------------------------------------------
ALERT_RECIPIENT_EMAILS=
ALERT_RECIPIENT_PHONES=
NOTIFY_CUSTOMER_ON_GENUINE=False

# ---------------------------------------------------------------------------
# Twilio SMS (leave blank to disable SMS)
# ---------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
